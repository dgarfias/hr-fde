# Database credentials used by the Postgres container and API connection string
POSTGRES_USER=happyrobot
POSTGRES_PASSWORD=happyrobot
POSTGRES_DB=happyrobot

# Bearer token required for protected backend endpoints used by HappyRobot webhook tools
API_KEY=hr-live-your-secret-key-here

# FMCSA API key used to verify carrier MC numbers
FMCSA_API_KEY=your-fmcsa-api-key

# Password required to log into the dashboard UI
DASHBOARD_PASSWORD=change-this-dashboard-password

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,https://your-domain.com

# Public API base URL used by the React dashboard
VITE_API_URL=http://localhost:8000

# Frontend env value kept for local dashboard compatibility
VITE_API_KEY=hr-live-your-secret-key-here
